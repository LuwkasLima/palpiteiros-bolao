# Copy to .env.local.
#
# LOCAL DEV: call the FastAPI backend directly (cross-origin; CORS is configured for it).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# PRODUCTION (Vercel) uses a same-origin proxy instead — set these in the Vercel `web`
# project, not here:
#   NEXT_PUBLIC_API_BASE_URL=/api
#   API_ORIGIN=https://<your-api-project>.vercel.app   (used by the next.config rewrite)
